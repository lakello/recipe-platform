values-secret.yaml
values-secrets.yaml
values.local.yaml
values-*.local.yaml

infra/helm/**/values-secret.yaml
infra/helm/**/values-secrets.yaml
infra/helm/**/values.local.yaml
infra/helm/**/values-*.local.yaml

